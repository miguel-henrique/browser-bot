APP_URL=https://www-sisgf/SisGF/faces/pages/index.xhtml
LOGIN_USER=your-username
LOGIN_PASSWORD="your-password"

# Browser settings
HEADLESS=true
IGNORE_HTTPS_ERRORS=true
NAVIGATION_TIMEOUT_MS=45000

# Retry and stability
MAX_RUN_ATTEMPTS=1
RETRY_DELAY_MS=3000
LOGIN_SUCCESS_URL_CONTAINS=
LOGIN_SUCCESS_SELECTOR="#messages .ui-messages-info-summary, #messages .ui-messages-info"
LOGIN_SUCCESS_TEXT="Ponto registrado com sucesso"
LOGIN_ERROR_SELECTOR=".ui-messages-error-summary, .ui-messages-error-detail, .ui-message-error-detail"
LOGIN_SETTLE_WAIT_MS=3000

# CAPTCHA controls
ENABLE_CAPTCHA=true
CAPTCHA_PROVIDER=ocr
CAPTCHA_MANUAL_FALLBACK=false
CAPTCHA_SUBMIT_MAX_ATTEMPTS=1
# Milliseconds to wait after filling the form (and captcha) before clicking submit
CAPTCHA_SUBMIT_DELAY_MS=1500
CAPTCHA_IMAGE_SELECTOR="img#j_idt141"
CAPTCHA_INPUT_SELECTOR="input#captchaId"

# OCR provider options
OCR_LANGUAGE=eng
OCR_NUMERIC_ONLY=true
OCR_EXPECTED_LENGTH=4
OCR_MIN_LENGTH=3
OCR_MAX_ATTEMPTS=10

# External provider options (example generic API)
CAPTCHA_API_URL=
CAPTCHA_API_KEY=
CAPTCHA_API_TIMEOUT_MS=30000

# Form selectors
USERNAME_SELECTOR="input#j_username"
PASSWORD_SELECTOR="input#j_password"
SUBMIT_SELECTOR="button#btnRegistrarPontoPresencial"

# Runtime
SCREENSHOT_DIR=./artifacts/screenshots
LOG_LEVEL=info
DEBUG_LOG_VALUES=false
TIMEZONE=America/Sao_Paulo
SCHEDULE_TIMES=07:00,11:25,12:25,16:00
# Dates to skip execution in DD/MM/YYYY separated by commas.
# Example: 01/05/2026,07/09/2026,24/12/2026
SKIP_DATES=

# Telegram fallback (used only if OCR fails and TELEGRAM_FALLBACK_ENABLED=true)
TELEGRAM_FALLBACK_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_REPLY_TIMEOUT_MS=180000
TELEGRAM_POLL_INTERVAL_MS=4000
