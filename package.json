{
  "name": "browser-bot",
  "version": "1.0.0",
  "description": "Scheduled Puppeteer automation with optional CAPTCHA solving",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "run:once": "RUN_ONCE=true node src/index.js",
    "check": "node --check src/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3",
    "puppeteer": "^24.9.0",
    "sharp": "^0.34.5",
    "tesseract.js": "^5.1.1"
  }
}
